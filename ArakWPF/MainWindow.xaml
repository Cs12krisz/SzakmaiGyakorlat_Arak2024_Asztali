<Window x:Class="ArakWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ArakWPF"
        mc:Ignorable="d"
        Title="2024-es árak" Height="450" Width="800"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="dtgArak" Grid.Row="1" ColumnWidth="*" SelectionChanged="dtgArak_SelectionChanged"/>
        <Label x:Name="lbTermek" Content="Termék" HorizontalAlignment="Left" Margin="245,17,0,0" VerticalAlignment="Top"/>
        <ProgressBar x:Name="pbAr" HorizontalAlignment="Left" Height="19" Margin="187,48,0,0" VerticalAlignment="Top" Width="168" Maximum="400" Minimum="-400"/>
        <Button x:Name="btnTorles" Content="Törlés" HorizontalAlignment="Left" Margin="430,0,0,0" VerticalAlignment="Center" Click="btnTorles_Click"/>
        <Button x:Name="btnMentes" Content="Mentés" HorizontalAlignment="Left" Margin="515,0,0,0" VerticalAlignment="Center" Click="btnMentes_Click"/>
    </Grid>
</Window>
