<Window x:Class="ArakWPF.Arak"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ArakWPF"
        mc:Ignorable="d"
        Title="HozzaadArak" Height="450" Width="800"
        Loaded="Window_Loaded">
    <Grid>
        <StackPanel>
            <Label Content="December"/>
            <TextBox x:Name="tbxDecember"/>
            <Label Content="Januar"/>
            <TextBox x:Name="tbxJanuar"/>
            <Label Content="Kod"/>
            <TextBox x:Name="tbxKod"/>
            <Label Content="Megnevezes"/>
            <TextBox x:Name="tbxMegnevezes"/>
            <Button Content="Hozzáad" Margin="0 10 0 0"/>
        </StackPanel>
    </Grid>
</Window>
